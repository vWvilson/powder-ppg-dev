{%- style -%}
  .page-header {
    position: relative;
    width: 100%;
    height: {{ section.settings.height }}px;
    overflow: hidden;
  }
  .page-header__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .page-header__overlay {
    position: absolute;
    inset: 0;
    width: 50%;
    height: 100%;
    left:50%;
    background-color: #2A2E37;
    display: flex;
    align-items: center;
    padding: 0 60px;
  }
  .page-header__title {
    color: #ffffff;
    font-size: {{ section.settings.title_size }}px;
    font-weight: 700;
    margin: 0;
    line-height: 1.2;
  }
  @media screen and (max-width: 768px) {
    .page-header__overlay {
      width: 100%;
      padding: 0 30px;
      background-color: rgba(42, 46, 55, 0.85);
    }
    .page-header__title {
      font-size: {{ section.settings.title_size | times: 0.7 | round }}px;
    }
  }
{%- endstyle -%}

<div class="page-header{% if section.settings.section_width == 'page' %} container{% endif %}" data-section-id="{{ section.id }}">
  {%- if section.settings.image != blank -%}
    <img
      class="page-header__bg"
      src="{{ section.settings.image | image_url: width: 2000 }}"
      srcset="{{ section.settings.image | image_url: width: 800 }} 800w,
              {{ section.settings.image | image_url: width: 1200 }} 1200w,
              {{ section.settings.image | image_url: width: 2000 }} 2000w"
      sizes="100vw"
      alt="{{ section.settings.image.alt | default: section.settings.title }}"
      loading="eager"
      width="{{ section.settings.image.width }}"
      height="{{ section.settings.image.height }}">
  {%- else -%}
    {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg page-header__bg' }}
  {%- endif -%}

  <div class="page-header__overlay">
    {%- if section.settings.title != blank -%}
      <h1 class="page-header__title">{{ section.settings.title }}</h1>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Page Image Header",
  "tag": "section",
  "class": "section-page-image-header",
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "Section Width",
      "options": [
        { "value": "full", "label": "Full Width" },
        { "value": "page", "label": "Page Width" }
      ],
      "default": "full"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Page Title"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Section Height",
      "min": 200,
      "max": 700,
      "step": 20,
      "default": 400,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title Size",
      "min": 20,
      "max": 72,
      "step": 2,
      "default": 42,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Page Image Header"
    }
  ]
}
{% endschema %}
