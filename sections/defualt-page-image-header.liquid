{%- style -%}
  .page-header {
    position: relative;
    width: 100%;
    height: {{ section.settings.height }}px;
    overflow: hidden;
    margin: 50px auto;
  }
  .page-header__photo {
    position: absolute;
    inset: 0;
    width: 70%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }
  .page-header__overlay {
    position: absolute;
    inset: 0;
    clip-path: polygon(58% 0%, 100% 0%, 100% 100%, 48% 100%);
    background: #2A2E37;
    box-shadow: inset -80px 0 120px rgba(0,0,0,0.25);
  }
  .page-header__label {
position: absolute;
    right: 6%;
    width: 40%;
    text-align: center;
    top: 50%;
    transform: translateY(-50%);
    font-weight: 300;
    max-width: 50%;
    font-size: clamp(2rem, 6vw, 72px);
    letter-spacing: 0.18em;
    color: #ffffff;
  
  }

  @media screen and (max-width: 768px) {
    .page-header__overlay {
      clip-path: none;
      background: rgba(42, 46, 55, 0.75);
    }
    .page-header__label {
      right: auto;
      left: 50%;
      transform: translate(-50%, -50%);
      text-align: center;
    }
    .page-header__label::before {
      display: none;
    }
  }
{%- endstyle -%}

<div class="page-header{% if section.settings.section_width == 'page' %} container{% endif %}" data-section-id="{{ section.id }}">
  {%- if section.settings.image != blank -%}
    <img
      class="page-header__photo"
      src="{{ section.settings.image | image_url: width: 2000 }}"
      srcset="{{ section.settings.image | image_url: width: 800 }} 800w,
              {{ section.settings.image | image_url: width: 1200 }} 1200w,
              {{ section.settings.image | image_url: width: 2000 }} 2000w"
      sizes="100vw"
      alt="{{ section.settings.image.alt | default: section.settings.title }}"
      loading="eager"
      width="{{ section.settings.image.width }}"
      height="{{ section.settings.image.height }}">
  {%- else -%}
    {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg page-header__photo' }}
  {%- endif -%}

  <div class="page-header__overlay"></div>

  {%- if section.settings.title != blank -%}
    <h1 class="page-header__label">{{ section.settings.title }}</h1>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Page Image Header",
  "tag": "section",
  "class": "section-page-image-header",
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "Section Width",
      "options": [
        { "value": "full", "label": "Full Width" },
        { "value": "page", "label": "Page Width" }
      ],
      "default": "full"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Page Title"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Section Height",
      "min": 200,
      "max": 700,
      "step": 20,
      "default": 400,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title Size",
      "min": 20,
      "max": 100,
      "step": 2,
      "default": 92,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Page Image Header"
    }
  ]
}
{% endschema %}
