        },
        {
          "type": "header",
          "content": "Button"
        },
        {
          "type": "text",
          "id": "button_label",
          "default": "Submit",
          "label": "Button label"
        },
        {
          "type": "color",
          "id": "button_bg",
          "default": "#0b5ea8",
          "label": "Button background"
        },
        {
          "type": "color",
          "id": "button_text",
          "default": "#ffffff",
          "label": "Button text color"
        },
        {
          "type": "range",
          "id": "button_radius",
          "min": 0,
          "max": 24,
          "step": 1,
          "unit": "px",
          "default": 2,
          "label": "Button border radius"
        },
        {
          "type": "header",
          "content": "Messages"
        },
        {
          "type": "text",
          "id": "success_message",
          "default": "Thanks for contacting us. We'll get back to you as soon as possible.",
          "label": "Success message"
        },
        {
          "type": "richtext",
          "id": "form_note",
          "default": "<p>We typically respond within 24 hours.</p>",
          "label": "Form note (optional)"
        }
      ]
    },

    {
      "type": "field_text",
      "name": "Field: Text",
      "settings": [
        {
          "type": "text",
          "id": "group_label",
          "label": "Group label (shown above, full width)",
          "info": "Optional. Use to add a heading that spans across paired half-width fields."
        },
        {
          "type": "text",
          "id": "label",
          "default": "First name",
          "label": "Label"
        },
        {
          "type": "text",
          "id": "name_key",
          "default": "First Name",
          "label": "Contact field key",
          "info": "This becomes contact[Your Key] in the submission payload."
        },

        {
          "type": "select",
          "id": "input_type",
          "label": "Input type",
          "default": "text",
          "options": [
            { "value": "text", "label": "Text" },
            { "value": "email", "label": "Email" },
            { "value": "tel", "label": "Phone" }
          ]
        },
        {
          "type": "text",
          "id": "autocomplete",
          "default": "given-name",
          "label": "Autocomplete attribute",
          "info": "Examples: given-name, family-name, email, tel."
        },
        {
          "type": "checkbox",
          "id": "required",
          "default": true,
          "label": "Required"
        },
        {
          "type": "checkbox",
          "id": "half_width",
          "default": true,
          "label": "Half width on desktop"
        }
      ]
    },
    {
      "type": "field_select",
      "name": "Field: Select",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "default": "Reason for contacting",
          "label": "Label"
        },
        {
          "type": "text",
          "id": "name_key",
          "default": "Reason For Contacting",
          "label": "Contact field key",
          "info": "This becomes contact[Your Key] in the submission payload."
