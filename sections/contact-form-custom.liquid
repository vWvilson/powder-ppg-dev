          "content": "Labels"
        },
        {
          "type": "color",
          "id": "label_color",
          "default": "#333333",
          "label": "Label color"
        },
        {
          "type": "range",
          "id": "label_size",
          "min": 11,
          "max": 18,
          "step": 1,
          "unit": "px",
          "default": 12,
          "label": "Label size"
        },
        {
          "type": "header",
          "content": "Inputs"
        },
        {
          "type": "color",
          "id": "input_bg",
          "default": "#ffffff",
          "label": "Input background"
        },
        {
          "type": "color",
          "id": "input_text",
