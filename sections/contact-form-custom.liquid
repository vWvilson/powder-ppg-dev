        },
        {
          "type": "color",
          "id": "heading_color",
          "default": "#111111",
          "label": "Heading color"
        },
        {
          "type": "header",
          "content": "Container"
        },
        {
          "type": "color",
          "id": "form_bg",
          "default": "#ffffff",
          "label": "Form background"
        },
        {
          "type": "color",
          "id": "form_border",
          "default": "#d9d9d9",
          "label": "Form border color"
        },
        {
          "type": "range",
          "id": "form_radius",
          "min": 0,
